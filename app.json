{
  "expo": {
    "name": "SovereignLedger",
    "slug": "sovereignledger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0E1A",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sovereignledger.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SovereignLedger uses your camera for facial liveness verification to secure your financial dashboard.",
        "NSFaceIDUsageDescription": "SovereignLedger uses Face ID to protect access to your financial data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.sovereignledger.app",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SovereignLedger to access your camera for liveness verification."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "sovereignledger"
  }
}